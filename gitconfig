[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
[user]
  name = Bryan Helmkamp
  email = bryan@brynary.com
	signingkey = EDB7F3CD464971E2
[alias]
  co = checkout
  ci = commit
  st = status
  br = branch
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
  type = cat-file -t
  dump = cat-file -p
[github]
  user = brynary
[core]
  autocrlf = input
  safecrlf = true
	excludesfile = /Users/bhelmkamp/.gitignore
[push]
  default = simple
	autoSetupRemote = true
	followTags = true
[commit]
	gpgsign = true
	verbose = true
[gpg]
	program = gpg
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[init]
	defaultBranch = main
[diff]
	algorithm = histogram
	colorMoved = plain
	renames = true
	mnemonicPrefix = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[help]
	autocorrect = prompt
[rerere]
	enabled = true
	autoupdate = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[pull]
	rebase = true
